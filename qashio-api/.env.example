# Local development (outside Docker) — use localhost and mapped ports
# For Docker, env vars are injected via docker-compose.yml

# App
NODE_ENV=development
PORT=3000

# Database (localhost:5433 maps to Docker Postgres container)
DATABASE_URL=postgresql://postgres:password@localhost:5433/qashio_points

# Swagger (only used in production)
SWAGGER_USER=admin
SWAGGER_PASSWORD=changeme

# Kafka
KAFKA_BROKER=localhost:9092